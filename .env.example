# =========================
# App
# =========================
AGENT_APP_NAME=Controlled Linux Server Agent
AGENT_APP_ENV=development
AGENT_DEBUG=true

# Local audit storage (SQLite)
AGENT_DATABASE_PATH=data/audit.sqlite3

# Policy configs
AGENT_POLICY_RULES_PATH=app/config/policy_rules.yaml
AGENT_TOOL_POLICIES_PATH=app/config/tool_policies.yaml
AGENT_CONFIRMATION_TTL_MINUTES=10

# Execution mode: dry_run | real
AGENT_EXECUTION_MODE=real

# =========================
# SSH target (Linux VM)
# =========================
AGENT_DEFAULT_TARGET_HOST=ubuntu-vm
AGENT_SSH_HOST=192.168.218.129
AGENT_SSH_PORT=22
AGENT_SSH_USERNAME=your-user
AGENT_SSH_PASSWORD=your-password
AGENT_SSH_PRIVATE_KEY_PATH=
AGENT_SSH_STRICT_HOST_KEY=false
# Optional fallback for non-interactive automation.
# In interactive chat/confirm flows, the user will still be prompted to enter sudo password.
AGENT_SUDO_PASSWORD=

# =========================
# MySQL (optional)
# =========================
AGENT_MYSQL_ENABLED=false
AGENT_MYSQL_HOST=127.0.0.1
AGENT_MYSQL_PORT=3306
AGENT_MYSQL_DATABASE=agent_db
AGENT_MYSQL_USER=root
AGENT_MYSQL_PASSWORD=your-mysql-password
AGENT_MYSQL_CHARSET=utf8mb4

# =========================
# LLM (optional)
# =========================
AGENT_LLM_ENABLED=true
AGENT_LLM_MODEL=deepseek-chat
AGENT_LLM_BASE_URL=https://api.deepseek.com/v1
AGENT_LLM_API_KEY=your-api-key
DEEPSEEK_API_KEY=your-api-key
